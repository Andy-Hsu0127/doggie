# 依賴套件
node_modules/

# 環境變數（包含密碼，絕對不進版控）
.env
.env.local
.env.production

# 資料庫檔案（本地資料，不進版控）
prisma/*.db
prisma/*.db-journal

# 日誌檔案
logs/
*.log

# Next.js 建置輸出
.next/
out/

# 作業系統產生的檔案
.DS_Store
Thumbs.db
desktop.ini

# IDE 設定（個人設定不進版控）
.vscode/settings.json
.idea/

# 測試覆蓋率報告
coverage/

# 暫存檔案
*.tmp
*.temp
